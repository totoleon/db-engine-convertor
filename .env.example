# Database Engine Convertor - Example Configuration
# Copy this file to .env and fill in your values

# ===== API Keys =====
GEMINI_API_KEY=your-gemini-api-key-here
GCP_PROJECT_ID=hailongli-senseai

# ===== Source Data =====
SQLITE_DB_PATH=/home/hailongli/bird_data/dev_20240627/dev_databases/california_schools/california_schools.sqlite
SQLITE_QUERIES_PATH=/home/hailongli/db-engine-convertor/examples/california_schools_queries.csv

# ===== PostgreSQL Configuration =====
PG_HOST=136.119.143.89
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your-pg-password-here

# PostgreSQL Databases (for different examples)
PG_DB_1=california_schools           # Example 1: SQLite → PG
PG_DB_2=california_schools_from_bq   # Example 7: BQ → PG

# ===== MySQL Configuration =====
MYSQL_HOST=136.114.180.162
MYSQL_PORT=3306
MYSQL_USER=dbuser
MYSQL_PASSWORD=your-mysql-password-here

# MySQL Databases (for different examples)
MYSQL_DB_1=california_schools          # Example 2: SQLite → MySQL
MYSQL_DB_2=california_schools_from_pg  # Example 4: PG → MySQL

# ===== BigQuery Configuration =====
BQ_DATASET=california_schools_pg      # Example 6: PG → BQ

# ===== Cloud Spanner Configuration =====
SPANNER_INSTANCE=your-spanner-instance
SPANNER_DB=california_schools
